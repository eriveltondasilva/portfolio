{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "slug": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80,
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
        "description": "Unique identifier of the series in kebab-case (e.g. nextjs-pro)."
      },
      "title": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120,
        "description": "Human readable title of the series."
      },
      "description": {
        "type": "string",
        "minLength": 10,
        "maxLength": 300,
        "description": "Short summary describing the series content."
      },
      "publishedAt": {
        "type": "string",
        "format": "date",
        "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))$",
        "description": "Publication date in ISO format (YYYY-MM-DD)."
      },
      "status": {
        "default": "planned",
        "description": "Indicates the current state of the series.",
        "type": "string",
        "enum": ["planned", "in-progress", "complete"]
      },
      "cover": {
        "description": "Path to the cover image used for the series.",
        "type": "string",
        "allOf": [
          {
            "pattern": "^\\.\\/.*"
          },
          {
            "pattern": "\\.(png|jpg|jpeg|webp|avif)$"
          }
        ]
      }
    },
    "required": ["slug", "title", "description", "publishedAt", "status"],
    "additionalProperties": false,
    "title": "Series Metadata",
    "description": "Schema for validating metadata of a content series."
  }
}
