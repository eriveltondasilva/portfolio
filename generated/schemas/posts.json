{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "slug": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120,
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
        "description": "Unique identifier for the post."
      },
      "title": {
        "type": "string",
        "minLength": 1,
        "maxLength": 160,
        "description": "Human readable title of the post."
      },
      "description": {
        "type": "string",
        "minLength": 10,
        "maxLength": 300,
        "description": "Short summary of the post."
      },
      "tags": {
        "minItems": 1,
        "maxItems": 10,
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "description": "Tag identifier."
        },
        "description": "List of tags used to categorize the post."
      },
      "publishedAt": {
        "type": "string",
        "format": "date",
        "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))$",
        "description": "Publication date in ISO format (YYYY-MM-DD)."
      },
      "updatedAt": {
        "description": "Date of the last significant update to the post.",
        "type": "string",
        "format": "date",
        "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))$"
      },
      "status": {
        "default": "draft",
        "description": "Visibility state of the post.",
        "type": "string",
        "enum": [
          "draft",
          "published",
          "archived"
        ]
      },
      "authors": {
        "minItems": 1,
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "description": "Author slug."
        },
        "description": "List of author slugs associated with this post."
      },
      "series": {
        "description": "Series identifier if the post belongs to a series.",
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "order": {
        "description": "Position of the post inside the series.",
        "examples": [
          1,
          2,
          3
        ],
        "type": "integer",
        "exclusiveMinimum": 0,
        "maximum": 9007199254740991
      }
    },
    "required": [
      "slug",
      "title",
      "description",
      "tags",
      "publishedAt",
      "status",
      "authors"
    ],
    "additionalProperties": false,
    "title": "Post Frontmatter",
    "description": "Schema for validating frontmatter metadata of a blog post."
  }
}