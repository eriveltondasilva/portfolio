{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "slug": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80,
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
        "description": "Unique identifier of the author in kebab-case."
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "description": "Full name of the author."
      },
      "bio": {
        "type": "string",
        "minLength": 10,
        "maxLength": 300,
        "description": "Short summary of the author."
      },
      "skills": {
        "minItems": 1,
        "maxItems": 20,
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1,
          "description": "Skill name."
        },
        "description": "List of skills or technologies the author is proficient in."
      },
      "socials": {
        "type": "object",
        "properties": {
          "github": {
            "type": "string",
            "format": "uri",
            "description": "GitHub profile URL."
          },
          "linkedin": {
            "description": "LinkedIn profile URL.",
            "type": "string",
            "format": "uri"
          },
          "twitter": {
            "description": "Twitter profile URL.",
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "github"
        ],
        "additionalProperties": false,
        "description": "Social media profiles of the author."
      }
    },
    "required": [
      "slug",
      "name",
      "bio",
      "skills",
      "socials"
    ],
    "additionalProperties": false,
    "title": "Author Metadata",
    "description": "Schema for validating metadata of a blog author."
  }
}