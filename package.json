{
  "name": "portfolio",
  "description": "Uma aplicação de um portfólio pessoal com blog desenvolvida com Next.js e MDX.",
  "author": "Erivelton Silva <eriveltondasilva13@gmail.com>",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eriveltondasilva/portfolio.git"
  },
  "private": true,
  "type": "module",
  "license": "MIT",
  "keywords": [
    "nextjs",
    "reactjs",
    "portfolio"
  ],
  "imports": {
    "#/*": "./src/*",
    "#/content/*": "./content/*"
  },
  "scripts": {
    "dev": "bun --bun next dev",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "x-predev": "bun run build:indexes",
    "prebuild": "bun run build:indexes",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix --cache",
    "fmt": "bunx prettier . --check",
    "fmt:fix": "bunx prettier . --write --cache",
    "types": "tsc --noEmit",
    "fix": "bun run types && bun run lint:fix && bun run fmt:fix",
    "build:blog": "bun run scripts/generate-blog-index.ts",
    "build:projects": "bun run scripts/generate-projects-index.ts",
    "build:schemas": "bun run scripts/generate-zod-schemas.ts",
    "build:indexes": "bun run build:blog && bun run build:projects"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.2",
    "@next/third-parties": "^16.2.2",
    "@octokit/rest": "^22.0.1",
    "@types/mdx": "^2.0.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-tweet": "^3.3.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-mdx-import-media": "^1.4.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "rehype-unwrap-images": "^1.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gemoji": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.2",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
